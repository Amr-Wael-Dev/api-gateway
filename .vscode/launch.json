{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug local (tsx)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "users-service", "dev:debug"],
      "cwd": "${workspaceFolder}",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/services/users/dist/**/*.js"],
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Attach to Docker",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "address": "localhost",
      "localRoot": "${workspaceFolder}/services/users",
      "remoteRoot": "/app/services/users",
      "sourceMaps": true,
      "skipFiles": ["<node_internals>/**"],
      "restart": true
    }
  ]
}
